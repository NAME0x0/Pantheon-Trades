# ===== Arc / Canteen =====
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<key>
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app
ARC_CURRENCY=USDC

# Canteen CLI exports $RPC; mirror here for non-shell consumers
RPC=${ARC_RPC_URL}

# Deployer / agent wallet (testnet only — never commit real keys)
DEPLOYER_PRIVATE_KEY=
AGENT_WALLET_PRIVATE_KEY=

# Deployed contract addresses (fill after `forge script Deploy`)
THESIS_REGISTRY_ADDRESS=
AGENT_SCORE_ADDRESS=
TRADE_PROOF_ADDRESS=
STAKING_VAULT_ADDRESS=

# ===== Circle =====
CIRCLE_API_KEY=
CIRCLE_GATEWAY_API_KEY=
CIRCLE_PAYMASTER_URL=
USDC_ADDRESS_ARC=

# ===== Polymarket =====
POLYMARKET_API_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# ===== Data adapters =====
HYPERLIQUID_API_BASE=https://api.hyperliquid.xyz
DEFILLAMA_API_BASE=https://api.llama.fi
COINDESK_API_BASE=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
NEWS_API_KEY=
BLOOMBERG_API_KEY=

# ===== LLM providers =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
DEFAULT_MODEL=anthropic/claude-opus-4-7
FAST_MODEL=anthropic/claude-haiku-4-5

# ===== Trace storage =====
TRACE_BACKEND=local            # local | ipfs | irys
IPFS_API_URL=
IPFS_GATEWAY_URL=
IRYS_NODE_URL=
IRYS_PRIVATE_KEY=

# ===== Database =====
DATABASE_URL=postgresql://signalforge:signalforge@localhost:5432/signalforge
REDIS_URL=redis://localhost:6379

# ===== API service =====
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WS_URL=ws://localhost:8000/ws

# ===== Web app =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_CHAIN_ID=5042002

# ===== Runtime flags =====
ENV=development                # development | staging | production
LOG_LEVEL=info
EXECUTION_MODE=paper           # paper | testnet | live
ENABLE_LIVE_TRADING=false
RISK_GATE_STRICT=true
