# Pantheon Trades environment template.
# Copy to .env (gitignored) and fill in values. Required keys are flagged.

# ===== Arc Testnet chain =====
RPC_URL=https://rpc.testnet.arc.network                      # required
CHAIN_ID=5042002                                              # required
ARC_EXPLORER_URL=https://testnet.arcscan.app

# Deployer / signer wallet. Never commit a mainnet key.
PRIVATE_KEY=                                                  # required for deploys + anchor() + live trading

# Deployed contract addresses (fill after running DeployPantheon.s.sol).
PARTHENON_REGISTRY_ADDRESS=                                   # required for AnchorService
PANTHEON_CONSTITUTION_ADDRESS=
ERC8004_REGISTRY_ADDRESS=                                     # required for parthenon.erc8004_client
PROOF_OF_RESTRAINT_ADDRESS=                                   # enables Areopagus on-chain witness writes

# ===== LLM providers (Boule deliberation) =====
# Either ANTHROPIC_API_KEY or GEMINI_API_KEY is required.
# Select provider via BOULE_LLM_PROVIDER=anthropic|gemini (default: anthropic).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Override defaults if needed.
# BOULE_GEMINI_MODEL=gemini-2.5-flash-lite      # 1000 RPD free tier
# BOULE_GEMINI_CONCURRENCY=1                     # serial calls
# BOULE_GEMINI_MIN_SPACING_SECONDS=6.0           # ~10 RPM ceiling
# BOULE_ANTHROPIC_MODEL=claude-sonnet-4-6
# Persistent disk cache for completions — identical prompt = zero
# network calls. Set to 0 to force every call to hit the provider.
# BOULE_LLM_CACHE=1
# BOULE_LLM_CACHE_DIR=.cache/boule-llm

# ===== Polymarket CLOB (Strategos live mode only) =====
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ===== Pythia data sources =====
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pantheon-pythia/0.1
NEWS_FEEDS=                                                   # comma-separated RSS URLs (optional)

# ===== Parthenon storage =====
IPFS_API_URL=http://localhost:5001
IPFS_AUTH=                                                    # e.g. "Bearer <token>" for pinning services
IRYS_NODE_URL=https://node1.irys.xyz
IRYS_TOKEN=matic
IRYS_JWK_PATH=                                                # path to wallet JWK json (optional)

# ===== Database / queue =====
DATABASE_URL=postgresql+asyncpg://pantheon:pantheon@localhost:5432/pantheon
REDIS_URL=redis://localhost:6379/0

# ===== API gateway =====
SECRET_KEY=change-me-in-production                            # itsdangerous session signing key
CORS_ORIGINS=http://localhost:3000
PANTHEON_ADMINS=                                              # comma-separated 0x addresses with admin role
PANTHEON_OPERATORS=                                           # comma-separated 0x addresses with operator role

# ===== Strategos runtime =====
EXECUTION_MODE=paper                                          # paper | live | auto
PORTFOLIO_USDC=10000                                          # starting paper book size

# ===== Logging / runtime flags =====
LOG_LEVEL=info
STRUCTLOG_JSON=0                                              # 1 in production
DEBUG=false
