# Pantheon Trades environment template.
# Copy to .env (gitignored) and fill in values. Required keys are flagged.

# ===== Arc Testnet chain =====
RPC_URL=https://rpc.testnet.arc.network                      # required
CHAIN_ID=5042002                                              # required
ARC_EXPLORER_URL=https://testnet.arcscan.app

# Deployer / signer wallet. Never commit a mainnet key.
PRIVATE_KEY=                                                  # required for deploys + anchor() + live trading

# Deployed contract addresses (fill after running DeployPantheon.s.sol).
PARTHENON_REGISTRY_ADDRESS=                                   # required for AnchorService
PANTHEON_CONSTITUTION_ADDRESS=
ERC8004_REGISTRY_ADDRESS=                                     # required for parthenon.erc8004_client
PROOF_OF_RESTRAINT_ADDRESS=                                   # enables Areopagus on-chain witness writes

# ===== LLM providers (Boule deliberation) =====
# Select provider via BOULE_LLM_PROVIDER. Any of:
#   anthropic | gemini | openai | openrouter | groq | together
#   | deepseek | xai | ollama | lm_studio | openai_compat
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=                                  # also used by openai_compat
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
# Generic OpenAI-compatible escape hatch (vLLM, LocalAI, TGI, custom):
# OPENAI_BASE_URL=https://your-proxy/v1
# OPENAI_MODEL=your-model-name
# Local backends (ignore auth):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=local-model
# Tuning knobs (provider-agnostic where applicable):
# BOULE_GEMINI_MODEL=gemini-2.5-flash-lite        # 1000 RPD free tier
# BOULE_GEMINI_CONCURRENCY=1
# BOULE_GEMINI_MIN_SPACING_SECONDS=6.0
# BOULE_ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_CONCURRENCY=4
# OPENAI_MIN_SPACING_SECONDS=0.0
# OPENAI_TEMPERATURE=0.4
# Persistent disk cache for completions — identical prompt = zero
# network calls. Set to 0 to force every call to hit the provider.
# BOULE_LLM_CACHE=1
# BOULE_LLM_CACHE_DIR=.cache/boule-llm

# ===== Pythia news search (optional) =====
# Brave Search API gives the best signal; GDELT is the no-key fallback.
BRAVE_API_KEY=
# NEWS_SEARCH_TIMEOUT_S=8

# ===== Chronos scheduler (cron loops) =====
# CHRONOS_APOLLO_CRON=*/5 * * * *
# CHRONOS_BOULE_SWEEP_CRON=*/15 * * * *
# CHRONOS_ANCHOR_RETRY_CRON=*/30 * * * *

# ===== Polymarket CLOB (Strategos live mode only) =====
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# When Polymarket geo-blocks your network, deploy the Vercel edge
# proxy at apps/web/app/api/polymarket-proxy/ and point these env
# vars at the deployed URL. Leave blank to hit the official hosts
# directly when reachable.
POLYMARKET_CLOB=                                              # e.g. https://your-app.vercel.app/api/polymarket-proxy/clob
POLYMARKET_GAMMA=                                             # e.g. https://your-app.vercel.app/api/polymarket-proxy/gamma
POLYMARKET_PROXY_TOKEN=                                       # shared secret guarding the proxy (optional, recommended)

# Polymarket V2 builder code program — earns daily USDC rebates on
# every fill that originates from our recommendations. Builder code
# is registered separately via the Polymarket dashboard.
POLYMARKET_BUILDER_CODE=                                       # short identifier (max 32 chars), set after approval
POLYMARKET_BUILDER_PAYOUT=                                     # 0x-prefixed Polygon address receiving daily USDC payout
POLYMARKET_BUILDER_SHARE=0.20                                  # protocol share (0.20-0.25 typical)

# ===== Pythia data sources =====
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pantheon-pythia/0.1
NEWS_FEEDS=                                                   # comma-separated RSS URLs (optional)

# ===== Parthenon storage =====
IPFS_API_URL=http://localhost:5001
IPFS_AUTH=                                                    # e.g. "Bearer <token>" for pinning services
IRYS_NODE_URL=https://node1.irys.xyz
IRYS_TOKEN=matic
IRYS_JWK_PATH=                                                # path to wallet JWK json (optional)

# ===== Database / queue =====
DATABASE_URL=postgresql+asyncpg://pantheon:pantheon@localhost:5432/pantheon
REDIS_URL=redis://localhost:6379/0

# ===== API gateway =====
SECRET_KEY=change-me-in-production                            # itsdangerous session signing key
CORS_ORIGINS=http://localhost:3000
PANTHEON_ADMINS=                                              # comma-separated 0x addresses with admin role
PANTHEON_OPERATORS=                                           # comma-separated 0x addresses with operator role

# ===== Strategos runtime =====
EXECUTION_MODE=paper                                          # paper | live | auto
PORTFOLIO_USDC=10000                                          # starting paper book size

# ===== Logging / runtime flags =====
LOG_LEVEL=info
STRUCTLOG_JSON=0                                              # 1 in production
DEBUG=false
